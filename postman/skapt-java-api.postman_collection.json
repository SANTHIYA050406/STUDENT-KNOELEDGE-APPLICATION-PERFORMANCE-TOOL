          "raw": "{\n  \"username\": \"student1\",\n  \"password\": \"password123\",\n  \"role\": \"student\",\n  \"studentProfile\": {\n    \"name\": \"Student One\",\n    \"rollNo\": \"CSE001\",\n    \"department\": \"CSE\",\n    \"cgpa\": 8.4\n  }\n}"
